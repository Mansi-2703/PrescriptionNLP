# Prescription NLP - Environment Configuration
# =============================================
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env with real API keys to version control!

# Google Gemini API Key (Required for Layer 3 & 4 LLM processing)
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_actual_api_key_here

# Optional: Database or other credentials
# DATABASE_URL=your_database_url
# OTHER_API_KEY=your_other_key
